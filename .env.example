# Catalyst Configuration - Environment Variables

# LLM Provider Configuration
# Options: "huggingface", "ollama", "mock"
LLM_API_PROVIDER=mock

# HuggingFace Inference API Token (for production)
# Get free token: https://huggingface.co/settings/tokens
HF_API_TOKEN="YOUR HF TOKEN HERE"

# Debug Mode (show verbose logging)
DEBUG=False

# Optional: Customize LLM Model
# Default: deepseek-ai/deepseek-7b-chat
# LLM_MODEL=meta-llama/Llama-2-7b-chat-hf
